{
  "name": "@tyrannoapartment/harn",
  "version": "2.1.3",
  "description": "AI multi-agent sprint development loop orchestrator (Planner → Generator → Evaluator)",
  "type": "module",
  "keywords": [
    "ai",
    "agents",
    "sprint",
    "planner",
    "cli",
    "copilot",
    "claude"
  ],
  "homepage": "https://github.com/Tyrannoapartment/harn",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tyrannoapartment/harn.git"
  },
  "scripts": {
    "dev": "node src/cli.js",
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build",
    "dev:homepage": "cd homepage && npm run dev",
    "build:homepage": "cd homepage && npm run build",
    "lint": "for f in src/**/*.js src/*.js; do node --check $f || exit 1; done && echo '✓ syntax OK'",
    "test": "for f in src/**/*.js src/*.js; do node --check $f || exit 1; done && echo '✓ syntax OK'",
    "postinstall": ""
  },
  "license": "MIT",
  "bin": {
    "harn": "./src/cli.js"
  },
  "files": [
    "src/",
    "prompts/",
    "web/dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "open": "^10.1.0",
    "inquirer": "^12.6.0"
  }
}
